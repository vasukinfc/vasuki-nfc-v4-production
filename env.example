# Sample Render Environment Variables
# Add real keys only in the Render dashboard. Do not store real secrets in GitHub or ZIP files.

NODE_ENV=production
NODE_VERSION=20
# Render injects PORT automatically. Use 10000 only for local Render-style smoke tests.
PORT=10000
PUBLIC_BASE_URL=https://your-render-app-name.onrender.com
ADMIN_EMAIL=vasukinfc@gmail.com
AUTH_SECRET=change-this-long-random-secret
MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=vasukinfc_v4

# Phase 8A platform hardening.
# Render and most single-proxy hosts should use 1.
TRUST_PROXY=1
# Set true in production after every validation issue below is resolved.
FAIL_ON_INVALID_ENV=false
STRUCTURED_LOGGING_ENABLED=true
LOG_LEVEL=info
STATIC_ASSET_MAX_AGE_SECONDS=86400
CUSTOMER_AUTH_RATE_LIMIT=20
ADMIN_AUTH_RATE_LIMIT=10
PUBLIC_ANALYTICS_RATE_LIMIT=240
ORDER_LOOKUP_RATE_LIMIT=20

# Media storage adapter. Local is the only enabled provider in CF3.
# In production, PROFILE_EDITOR_ENABLED=true requires an explicitly mounted
# persistent directory and MEDIA_STORAGE_LOCAL_PERSISTENT=true.
# Provider names s3, r2 and firebase are reserved but intentionally disabled.
MEDIA_STORAGE_PROVIDER=local
MEDIA_STORAGE_LOCAL_ROOT=
MEDIA_STORAGE_LOCAL_PERSISTENT=false

# Phase 1A Admin CRM shell. Keep false until the admin module is ready to use.
ADMIN_CRM_ENABLED=false
# Use a separate random value of at least 32 characters in production.
ADMIN_SESSION_SECRET=change-this-admin-session-secret-at-least-32-characters
# Absolute administrator session lifetime in hours.
ADMIN_SESSION_HOURS=8

# Phase 4A Customer Profile Editor. Keep false until the protected editor is ready to expose.
PROFILE_EDITOR_ENABLED=false

# Phase 5B Customer Subscription Dashboard. No payment processing is enabled.
SUBSCRIPTION_ENGINE_ENABLED=false
# Subscription lifecycle defaults.
SUBSCRIPTION_FREE_TRIAL_DAYS=14
SUBSCRIPTION_GRACE_PERIOD_DAYS=7
SUBSCRIPTION_REMINDER_DAYS=7,3,1
SUBSCRIPTION_CURRENCY=INR

# Phase 6A in-app Notification Center. External delivery remains disabled.
NOTIFICATION_ENGINE_ENABLED=false
NOTIFICATION_EXPIRY_WARNING_DAYS=30,15,7,3,1

# Phase 7A Analytics Platform. Public tracking and dashboards remain disabled until enabled.
ANALYTICS_PLATFORM_ENABLED=false
# Use a separate random secret in production; raw visitor identifiers are never stored.
ANALYTICS_HASH_SECRET=change-this-analytics-hash-secret
ANALYTICS_MAX_REPORT_EVENTS=100000

# Keep Test Mode in staging/QA. Use live keys only during the final approved
# production payment launch.
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_test_key_secret

# Email/OTP delivery. Use either BREVO_API_KEY or SMTP_* credentials.
BREVO_API_KEY=
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VASUKI NFC <your_verified_sender_email>

# Optional admin/order notification channels.
ADMIN_WHATSAPP=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0

# Bootstrap-only. Set only while creating the first admin, then remove.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_NAME=
ADMIN_BOOTSTRAP_PASSWORD=
